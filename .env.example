# ───────────────────────────────────────────────────────────────────────────
# FastBadge environment configuration
# Copy this file to `.env` and fill in the values you need.
# If NO Google credentials are provided, the server runs in MOCK-DATA mode
# so the whole app remains testable without any cloud setup.
# ───────────────────────────────────────────────────────────────────────────

# Port the Express server listens on (the app must be reached at http://localhost
# for the browser to enable Web Bluetooth and the camera).
PORT=3000

# The target spreadsheet id (the long token in the sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit )
GOOGLE_SHEETS_ID=

# A1-style range that contains the attendee table, including a header row.
# Expected header columns: id | name | company | role | status
SHEET_RANGE=Attendees!A:E

# ── Auth option A: API key (read-only) ──────────────────────────────────────
# Simplest for verification. Cannot write status back unless the sheet is
# publicly editable (not recommended). Use a service account for real check-ins.
GOOGLE_API_KEY=

# ── Auth option B: Service account (read + write, recommended) ───────────────
# Create a service account, download its JSON key, and share the spreadsheet
# with the service-account email as an Editor.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private key on a single line, keeping the literal \n escapes.
GOOGLE_PRIVATE_KEY=
